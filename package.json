{
  "name": "action-size",
  "version": "2.2.0",
  "private": true,
  "description": "Counts the number of lines changed in a pull request",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc && ncc build",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/action-size.git"
  },
  "keywords": [
    "actions",
    "github",
    "pull-request",
    "label"
  ],
  "author": "step-security",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/github": "^8.0.1",
    "axios": "1.15.0",
    "semver": "^6.1.1"
  },
  "devDependencies": {
    "@octokit/webhooks": "^14.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "@types/semver": "^7.7.1",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.26.0",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jest-circus": "^29.7.0",
    "js-yaml": "^3.14.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.9",
    "typescript": "^5.4.0"
  }
}
