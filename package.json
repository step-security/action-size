{
  "name": "action-size",
  "version": "2.2.0",
  "private": true,
  "description": "Counts the number of lines changed in a pull request",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc && ncc build",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/step-security/action-size.git"
  },
  "keywords": [
    "actions",
    "github",
    "pull-request",
    "label"
  ],
  "author": "step-security",
  "license": "Apache 2.0",
  "dependencies": {
    "@actions/core": "^1.2.3",
    "@actions/github": "^2.1.1",
    "@octokit/rest": "^22.0.1",
    "axios": "1.15.0",
    "semver": "^6.1.1"
  },
  "devDependencies": {
    "@octokit/webhooks": "^7.4.0",
    "@types/jest": "^24.0.23",
    "@types/node": "^20.0.0",
    "@types/semver": "^6.0.0",
    "@typescript-eslint/parser": "^3.1.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^5.16.0",
    "eslint-plugin-github": "^2.0.0",
    "eslint-plugin-jest": "^22.21.0",
    "eslint-plugin-prettier": "^3.1.3",
    "jest-circus": "^24.9.0",
    "js-yaml": "^3.14.0",
    "prettier": "^1.19.1",
    "ts-jest": "^24.2.0",
    "typescript": "^5.4.0"
  }
}
